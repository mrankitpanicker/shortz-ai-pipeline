{
    "annotations": {
        "list": []
    },
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "liveNow": false,
    "panels": [
        {
            "title": "Queue Length",
            "type": "stat",
            "datasource": "Prometheus",
            "gridPos": {
                "h": 6,
                "w": 6,
                "x": 0,
                "y": 0
            },
            "targets": [
                {
                    "expr": "shortz_queue_length",
                    "legendFormat": "Queue Length"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 5
                            },
                            {
                                "color": "red",
                                "value": 20
                            }
                        ]
                    }
                }
            }
        },
        {
            "title": "Workers Active",
            "type": "stat",
            "datasource": "Prometheus",
            "gridPos": {
                "h": 6,
                "w": 6,
                "x": 6,
                "y": 0
            },
            "targets": [
                {
                    "expr": "shortz_workers_active",
                    "legendFormat": "Active Workers"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "steps": [
                            {
                                "color": "blue",
                                "value": null
                            },
                            {
                                "color": "green",
                                "value": 1
                            }
                        ]
                    }
                }
            }
        },
        {
            "title": "Jobs Completed",
            "type": "stat",
            "datasource": "Prometheus",
            "gridPos": {
                "h": 6,
                "w": 6,
                "x": 12,
                "y": 0
            },
            "targets": [
                {
                    "expr": "shortz_jobs_complete",
                    "legendFormat": "Completed"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "fixedColor": "green",
                        "mode": "fixed"
                    }
                }
            }
        },
        {
            "title": "Jobs Failed",
            "type": "stat",
            "datasource": "Prometheus",
            "gridPos": {
                "h": 6,
                "w": 6,
                "x": 18,
                "y": 0
            },
            "targets": [
                {
                    "expr": "shortz_jobs_failed",
                    "legendFormat": "Failed"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "fixedColor": "red",
                        "mode": "fixed"
                    }
                }
            }
        },
        {
            "title": "Job Throughput (over time)",
            "type": "timeseries",
            "datasource": "Prometheus",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 6
            },
            "targets": [
                {
                    "expr": "shortz_worker_jobs_processed",
                    "legendFormat": "Total Processed"
                },
                {
                    "expr": "shortz_worker_jobs_failed",
                    "legendFormat": "Total Failed"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "line",
                        "lineInterpolation": "smooth",
                        "fillOpacity": 20,
                        "lineWidth": 2,
                        "pointSize": 4,
                        "showPoints": "auto"
                    }
                },
                "overrides": [
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "Total Failed"
                        },
                        "properties": [
                            {
                                "id": "color",
                                "value": {
                                    "fixedColor": "red",
                                    "mode": "fixed"
                                }
                            }
                        ]
                    }
                ]
            }
        },
        {
            "title": "Worker Uptime (seconds)",
            "type": "timeseries",
            "datasource": "Prometheus",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 6
            },
            "targets": [
                {
                    "expr": "shortz_worker_uptime_seconds",
                    "legendFormat": "Uptime"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 10,
                        "lineWidth": 2
                    },
                    "color": {
                        "fixedColor": "blue",
                        "mode": "fixed"
                    }
                }
            }
        },
        {
            "title": "Average Job Time",
            "type": "gauge",
            "datasource": "Prometheus",
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 0,
                "y": 14
            },
            "targets": [
                {
                    "expr": "shortz_worker_avg_job_time_seconds",
                    "legendFormat": "Avg Time"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "min": 0,
                    "max": 300,
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 60
                            },
                            {
                                "color": "red",
                                "value": 180
                            }
                        ]
                    }
                }
            }
        },
        {
            "title": "GPU Memory Usage (MB)",
            "type": "timeseries",
            "datasource": "Prometheus",
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 8,
                "y": 14
            },
            "targets": [
                {
                    "expr": "shortz_gpu0_memory_used_mb",
                    "legendFormat": "Used"
                },
                {
                    "expr": "shortz_gpu0_memory_total_mb",
                    "legendFormat": "Total"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "decmbytes",
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 15,
                        "lineWidth": 2
                    }
                },
                "overrides": [
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "Total"
                        },
                        "properties": [
                            {
                                "id": "custom.lineStyle",
                                "value": {
                                    "fill": "dash",
                                    "dash": [
                                        10,
                                        5
                                    ]
                                }
                            },
                            {
                                "id": "color",
                                "value": {
                                    "fixedColor": "gray",
                                    "mode": "fixed"
                                }
                            }
                        ]
                    }
                ]
            }
        },
        {
            "title": "GPU Utilization & Temperature",
            "type": "timeseries",
            "datasource": "Prometheus",
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 16,
                "y": 14
            },
            "targets": [
                {
                    "expr": "shortz_gpu0_utilization_pct",
                    "legendFormat": "GPU Util %"
                },
                {
                    "expr": "shortz_gpu0_temperature_c",
                    "legendFormat": "Temp °C"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 10,
                        "lineWidth": 2
                    }
                },
                "overrides": [
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "Temp °C"
                        },
                        "properties": [
                            {
                                "id": "color",
                                "value": {
                                    "fixedColor": "orange",
                                    "mode": "fixed"
                                }
                            }
                        ]
                    }
                ]
            }
        }
    ],
    "refresh": "15s",
    "schemaVersion": 39,
    "style": "dark",
    "tags": [
